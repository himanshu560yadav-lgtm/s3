<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawer"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- App Bar -->
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/topBar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@android:color/transparent"
            app:titleCentered="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Private"
                android:textStyle="bold"
                android:textSize="20sp"
                android:textColor="?attr/colorPrimary"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Agent"
                android:textSize="20sp"
                android:textColor="?attr/colorOnSurface"/>
        </com.google.android.material.appbar.MaterialToolbar>

        <!-- Mode selector -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginVertical="8dp"
            android:background="@drawable/bg_bubble_assistant"
            android:padding="4dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnModeChat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/Widget.Material3.Button.TonalButton"
                android:text="Chat"
                android:drawableLeft="@android:drawable/ic_dialog_email"/>

            <Button
                android:id="@+id/btnModeAgent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/Widget.Material3.Button.TonalButton"
                android:text="Agent"
                android:drawableLeft="@android:drawable/ic_menu_manage"/>
        </LinearLayout>

        <!-- API warning banner -->
        <LinearLayout
            android:id="@+id/apiWarning"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:visibility="gone"
            android:layout_marginHorizontal="16dp"
            android:layout_marginVertical="8dp"
            android:paddingHorizontal="16dp"
            android:paddingVertical="10dp"
            android:background="@drawable/bg_bubble_assistant">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="API not configured. Tap Settings to add details."
                android:textSize="12.5sp"
                android:textStyle="bold"/>

            <Button
                android:id="@+id/btnConfigure"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/Widget.Material3.Button.TonalButton"
                android:text="Configure"/>
        </LinearLayout>

        <!-- Chat list -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/chatList"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:clipToPadding="false"/>

        <!-- Thinking indicator -->
        <LinearLayout
            android:id="@+id/thinking"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="24dp"
            android:paddingVertical="8dp"
            android:visibility="gone">

            <ProgressBar
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:indeterminateTint="@color/indigo_500"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="Thinking..."
                android:textSize="12sp"
                android:textColor="?attr/colorOnSurface"/>

            <Button
                android:id="@+id/btnStop"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Stop"
                android:textColor="@color/red"
                style="@style/Widget.Material3.Button.TextButton"/>
        </LinearLayout>

        <!-- Input bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="24dp"
            android:paddingTop="8dp">

            <ImageButton
                android:id="@+id/btnMic"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_bubble_assistant"
                android:src="@android:drawable/ic_btn_speak_now"/>

            <EditText
                android:id="@+id/inputText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_bubble_assistant"
                android:paddingHorizontal="20dp"
                android:paddingVertical="12dp"
                android:hint="Type a command..."
                android:inputType="text"
                android:imeOptions="actionSend"/>

            <ImageButton
                android:id="@+id/btnSend"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="6dp"
                android:backgroundTint="?attr/colorPrimary"
                android:src="@android:drawable/ic_menu_send"
                app:tint="@color/white"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Navigation drawer -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navView"
        android:layout_width="300dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        app:headerLayout="@layout/nav_header"
        app:menu="@menu/drawer_menu"/>
</androidx.drawerlayout.widget.DrawerLayout>
